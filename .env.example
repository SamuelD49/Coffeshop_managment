PORT=3000
SESSION_SECRET=your_session_secret_here
NODE_ENV=development

# Driver selection — defaults keep the app running on local SQLite + local-disk
# uploads. Flip these to "supabase" after running the one-time copy scripts.
DB_DRIVER=sqlite
STORAGE_DRIVER=local

# Supabase config — only read when DB_DRIVER=supabase or STORAGE_DRIVER=supabase.
# See docs/SUPABASE_SETUP.md for where to find each value.
DATABASE_URL=your_database_url_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET=coffeeshop
SUPERADMIN_PASSWORD=your_superadmin_password_here
