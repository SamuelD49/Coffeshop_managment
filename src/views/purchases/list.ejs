<%- include('../partials/head', { title: 'Purchases', shopName }) %>
<body class="text-ink font-sans antialiased min-h-screen flex">
  <%- include('../partials/sidebar', { shopName, currentRole, currentUser, csrfToken, currentPath }) %>

  <main class="flex-1 px-air-lg pt-chapter pb-air-lg max-w-5xl">
    <%
      // The controller defaults filters.from/to to today. Detect that state so
      // we can show the right contextual copy below the title.
      const _isToday    = filters.from === today && filters.to === today;
      const _isFiltered = !_isToday && (filters.from || filters.to) && !showAll;
    %>
    <header class="reveal reveal-1 flex items-end justify-between gap-gutter">
      <div>
        <h1 class="font-display text-[36px] leading-[42px] text-ink" style="font-variation-settings:'opsz' 72,'SOFT' 50">Purchases</h1>
        <p class="font-sans text-[13px] text-smoke mt-gutter-tight">
          <% if (_isToday) { %>
            Today's entries. <a href="/reports?tab=purchases" class="link">See history in Reports →</a>
          <% } else if (showAll) { %>
            All purchases — <a href="/purchases" class="link">back to today</a>
          <% } else if (_isFiltered) { %>
            <span class="font-mono"><%= filters.from || '…' %></span> → <span class="font-mono"><%= filters.to || '…' %></span> — <a href="/purchases" class="link">back to today</a>
          <% } %>
        </p>
      </div>
      <details class="text-right">
        <summary class="font-sans text-[12px] tracking-smallcaps uppercase text-smoke hover:text-ink cursor-pointer transition-colors list-none">
          Filter by date
        </summary>
        <form method="GET" class="flex items-end gap-gutter mt-gutter justify-end">
          <label class="block">
            <span class="field-label">From</span>
            <input type="date" name="from" value="<%= filters.from || '' %>" class="field-input field-mono" />
          </label>
          <label class="block">
            <span class="field-label">To</span>
            <input type="date" name="to" value="<%= filters.to || '' %>" class="field-input field-mono" />
          </label>
          <button class="btn-secondary">Apply</button>
        </form>
        <div class="flex justify-end gap-gutter mt-gutter font-sans text-[12px] tracking-smallcaps uppercase">
          <a href="/purchases" class="text-smoke hover:text-ink transition-colors">Today</a>
          <span class="text-mist">·</span>
          <a href="/purchases?show=all" class="text-smoke hover:text-ink transition-colors">Show all</a>
        </div>
      </details>
    </header>

    <div class="reveal reveal-2"><%- include('../partials/ornament') %></div>

    <%- include('../partials/flash', { flash }) %>

    <%# Hidden form element referenced by the inline empty row below (HTML5 form= attribute) %>
    <form method="POST" action="/purchases" id="purchase-new" class="hidden">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    </form>

    <div class="reveal reveal-3 card overflow-x-auto">
      <table class="w-full table-fixed">
        <colgroup>
          <col style="width: 132px" />  <%# Date %>
          <col style="width: 28%"   />  <%# Description %>
          <col style="width: 56px"  />  <%# Un %>
          <col style="width: 72px"  />  <%# Qty %>
          <col style="width: 100px" />  <%# Price %>
          <col style="width: 108px" />  <%# Total %>
          <col style="width: 20%"   />  <%# Remark %>
          <col style="width: 132px" />  <%# Actions %>
        </colgroup>
        <thead>
          <tr class="border-b border-rule-strong">
            <th class="text-left  font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke px-gutter-lg py-gutter-lg">Date</th>
            <th class="text-left  font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke pr-gutter py-gutter-lg">Description</th>
            <th class="text-left  font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke pr-gutter py-gutter-lg">Un.</th>
            <th class="text-right font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke pr-gutter py-gutter-lg">Qty</th>
            <th class="text-right font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke pr-gutter py-gutter-lg">Price</th>
            <th class="text-right font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke pr-gutter py-gutter-lg">Total</th>
            <th class="text-left  font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke pl-gutter-lg pr-gutter py-gutter-lg">Remark</th>
            <th class="px-gutter-lg py-gutter-lg"></th>
          </tr>
        </thead>

        <%# Empty row at the top — exactly matches "fill in the next line" on the paper form %>
        <tbody>
          <tr class="border-b border-rule bg-paper">
            <td class="px-gutter-lg py-gutter-lg">
              <input form="purchase-new" type="date" name="purchase_date" value="<%= today %>" required class="w-full font-mono text-[13px] bg-transparent border-0 border-b border-rule-strong px-1 py-1 focus:outline-none focus:border-b-2 focus:border-ember" />
            </td>
            <td class="pr-gutter py-gutter-lg">
              <input form="purchase-new" name="description" required placeholder="Beans, milk, sugar…" class="w-full font-sans text-[15px] bg-transparent border-0 border-b border-rule-strong px-1 py-1 focus:outline-none focus:border-b-2 focus:border-ember" />
            </td>
            <td class="pr-gutter py-gutter-lg">
              <input form="purchase-new" name="unit" placeholder="kg" class="w-full font-mono text-[13px] bg-transparent border-0 border-b border-rule-strong px-1 py-1 focus:outline-none focus:border-b-2 focus:border-ember" />
            </td>
            <td class="pr-gutter py-gutter-lg">
              <input form="purchase-new" name="qty" required placeholder="0" class="w-full font-mono text-right text-[13px] bg-transparent border-0 border-b border-rule-strong px-1 py-1 focus:outline-none focus:border-b-2 focus:border-ember" />
            </td>
            <td class="pr-gutter py-gutter-lg">
              <input form="purchase-new" name="unit_price" required placeholder="0.00" class="w-full font-mono text-right text-[13px] bg-transparent border-0 border-b border-rule-strong px-1 py-1 focus:outline-none focus:border-b-2 focus:border-ember" />
            </td>
            <td class="pr-gutter py-gutter-lg text-right font-mono text-[13px] text-mist">—</td>
            <td class="pl-gutter-lg pr-gutter py-gutter-lg">
              <input form="purchase-new" name="remark" class="w-full font-sans text-[13px] bg-transparent border-0 border-b border-rule-strong px-1 py-1 focus:outline-none focus:border-b-2 focus:border-ember" />
            </td>
            <td class="px-gutter-lg py-gutter-lg text-right">
              <button form="purchase-new" class="font-sans text-[12px] tracking-smallcaps uppercase text-ember hover:text-ember-deep transition-colors">Add →</button>
            </td>
          </tr>

          <% purchases.forEach(p => { %>
            <tr class="border-b border-rule last:border-0 hover:bg-paper transition-colors align-top">
              <td class="px-gutter-lg py-gutter-lg font-mono text-[13px] text-coal whitespace-nowrap"><%= p.purchase_date %></td>
              <td class="pr-gutter py-gutter-lg font-sans text-[15px] text-ink leading-relaxed break-words"><%= p.description %></td>
              <td class="pr-gutter py-gutter-lg font-mono text-[13px] text-smoke"><%= p.unit || '' %></td>
              <td class="pr-gutter py-gutter-lg text-right font-mono text-[14px] text-coal"><%= p.qty %></td>
              <td class="pr-gutter py-gutter-lg text-right font-mono text-[14px] text-coal"><%= (p.unit_price / 100).toFixed(2) %></td>
              <td class="pr-gutter py-gutter-lg text-right font-mono text-[15px] text-ink"><%= (p.total / 100).toFixed(2) %></td>
              <td class="pl-gutter-lg pr-gutter py-gutter-lg font-sans text-[13px] text-smoke leading-relaxed break-words" title="<%= p.remark || '' %>"><%= p.remark || '' %></td>
              <td class="px-gutter-lg py-gutter-lg text-right whitespace-nowrap">
                <a href="/purchases/<%= p.id %>/edit" class="font-sans text-[12px] tracking-smallcaps uppercase text-smoke hover:text-ember transition-colors mr-gutter">Edit</a>
                <form method="POST" action="/purchases/<%= p.id %>/delete" class="inline"
                      data-confirm="This purchase row will be removed from the log."
                      data-confirm-title="Delete this row?"
                      data-confirm-label="Delete"
                      data-confirm-variant="danger">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="font-sans text-[12px] tracking-smallcaps uppercase text-smoke hover:text-crimson transition-colors">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>

          <% if (purchases.length === 0) { %>
            <tr>
              <td colspan="8" class="px-gutter-lg py-air text-center font-display italic text-[18px] text-mist" style="font-variation-settings:'opsz' 24,'SOFT' 50">
                <% if (_isToday) { %>
                  No purchases logged today — type into the line above to add one.
                <% } else { %>
                  No purchases in this range — widen the filter or <a href="/purchases" class="link">go back to today</a>.
                <% } %>
              </td>
            </tr>
          <% } %>
        </tbody>

        <tfoot>
          <tr class="border-t-2 border-rule-strong bg-paper">
            <td colspan="5" class="px-gutter-lg py-gutter-lg text-right font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke">Total</td>
            <td class="pr-gutter py-gutter-lg text-right font-mono text-[18px] text-ink"><%= (sumTotal / 100).toFixed(2) %></td>
            <td colspan="2"></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </main>
</body>
</html>
