<%
  // Visible only on phone (CSS hides on md+). Top header + bottom tab bar.
  // Owners get a 5-tab bar. Cashiers get a simpler 3-tab bar — no Reports/More.
  function isActive(href, current) {
    return href === '/' ? current === '/' : (current === href || current.startsWith(href + '/'));
  }
  function tabClass(href, current){ return 'tab-item' + (isActive(href, current) ? ' is-active' : ''); }

  const isOwner = currentRole === 'owner';
  // Show back link on detail/edit/new routes — anything deeper than one segment.
  const segs = currentPath.split('/').filter(Boolean);
  const showBack = segs.length >= 2;
  const backHref = segs.length >= 2 ? '/' + segs[0] : '/';
%>

<header class="app-header-mobile md:hidden" role="banner">
  <% if (showBack) { %>
    <a href="<%= backHref %>" class="app-header-back" aria-label="Back">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 6 9 12 15 18"></polyline>
      </svg>
    </a>
  <% } else { %>
    <span class="app-header-back-spacer" aria-hidden="true"></span>
  <% } %>
  <h1 class="app-header-title"><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : shopName %></h1>
  <span class="app-header-back-spacer" aria-hidden="true"></span>
</header>

<% if (isOwner) { %>
  <nav class="tab-bar md:hidden" aria-label="Primary">
    <a href="/" class="<%= tabClass('/', currentPath) %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/></svg>
      <span>Home</span>
    </a>
    <a href="/sales" class="<%= tabClass('/sales', currentPath) %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h18l-2 12H5L3 7z"/><path d="M8 7V5a4 4 0 018 0v2"/></svg>
      <span>Sales</span>
    </a>
    <a href="/purchases" class="<%= tabClass('/purchases', currentPath) %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="6" width="16" height="14" rx="1"/><path d="M8 10h8"/><path d="M9 3h6v3H9z"/></svg>
      <span>Purchases</span>
    </a>
    <a href="/petty-cash" class="<%= tabClass('/petty-cash', currentPath) %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="7" width="18" height="12" rx="2"/><circle cx="12" cy="13" r="2.2"/><path d="M7 11v4"/><path d="M17 11v4"/></svg>
      <span>Petty cash</span>
    </a>
    <button type="button" class="tab-item" id="tab-more" aria-haspopup="dialog" aria-controls="more-sheet">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="5" cy="12" r="1.2"/><circle cx="12" cy="12" r="1.2"/><circle cx="19" cy="12" r="1.2"/></svg>
      <span>More</span>
    </button>
  </nav>
<% } else { %>
  <nav class="tab-bar md:hidden" aria-label="Primary">
    <a href="/" class="<%= tabClass('/', currentPath) %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/></svg>
      <span>Home</span>
    </a>
    <a href="/sales/new" class="<%= tabClass('/sales/new', currentPath) %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
      <span>New</span>
    </a>
    <a href="/sales" class="<%= tabClass('/sales', currentPath) %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>
      <span>History</span>
    </a>
  </nav>
<% } %>

<% if (isOwner && currentUser) { %>
  <div class="sheet-backdrop md:hidden" id="more-backdrop" aria-hidden="true"></div>
  <div class="sheet md:hidden" id="more-sheet" role="dialog" aria-modal="true" aria-labelledby="more-sheet-title" aria-hidden="true">
    <div class="sheet-grip" aria-hidden="true"></div>
    <h2 class="sheet-title" id="more-sheet-title">More</h2>
    <nav class="sheet-list" aria-label="Secondary">
      <a href="/reports"    class="sheet-item">Reports</a>
      <a href="/menu"       class="sheet-item">Menu</a>
      <a href="/employees"  class="sheet-item">Employees</a>
      <a href="/payroll"    class="sheet-item">Payroll</a>
      <a href="/settings"   class="sheet-item">Settings</a>
      <a href="/account"    class="sheet-item">Account</a>
      <form action="/logout" method="POST" class="sheet-item-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="sheet-item sheet-item-button">Log out</button>
      </form>
    </nav>
  </div>
<% } %>

<script>
  // Bottom-sheet "More" panel — slides up from the tab bar.
  (function(){
    var btn = document.getElementById('tab-more');
    var sheet = document.getElementById('more-sheet');
    var backdrop = document.getElementById('more-backdrop');
    if (!btn || !sheet || !backdrop) return;
    function open(){
      sheet.classList.add('is-open');
      backdrop.classList.add('is-open');
      sheet.setAttribute('aria-hidden','false');
      document.body.classList.add('sheet-open');
    }
    function close(){
      sheet.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      sheet.setAttribute('aria-hidden','true');
      document.body.classList.remove('sheet-open');
    }
    btn.addEventListener('click', open);
    backdrop.addEventListener('click', close);
    // Tapping a link inside the sheet should close it before navigating.
    sheet.querySelectorAll('a, button').forEach(function(el){
      el.addEventListener('click', function(){ setTimeout(close, 0); });
    });
    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape' && sheet.classList.contains('is-open')) close();
    });
  })();
</script>
