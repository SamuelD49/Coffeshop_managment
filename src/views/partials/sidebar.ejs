<a href="#main" class="skip-link">Skip to main content</a>

<%- include('./mobile-nav', { shopName, currentRole, currentUser, csrfToken, currentPath, pageTitle: typeof pageTitle !== 'undefined' ? pageTitle : '' }) %>

<aside id="app-sidebar" class="w-60 min-h-screen px-gutter-lg pt-air pb-air border-r border-rule-strong flex-col hidden md:flex" aria-label="Main navigation" hx-boost="true">
  <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin && shopId) { %>
    <div class="mb-gutter p-3 bg-ember/30 border border-ember text-ember-deep rounded-soft text-[12px] font-sans">
      <div class="font-bold flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-ember animate-pulse"></span>
        SaaS Impersonation
      </div>
      <div class="text-smoke mt-0.5">Active on <%= shopName %></div>
      <form action="/superadmin/impersonate/exit" method="POST" class="mt-2" hx-boost="false">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button class="w-full text-center py-1 bg-ember text-ember-deep font-semibold rounded-soft border border-ember-deep/20 hover:bg-ember/80 transition-colors">
          Exit Control
        </button>
      </form>
    </div>
  <% } %>
  
  <a href="/" class="wordmark text-[28px] leading-[32px] mb-air block">
    <%= shopName %>
  </a>

  <%
    function initials(name){ return name.split(/\s+/).filter(Boolean).slice(0,2).map(s => s[0].toUpperCase()).join(""); }
    function isActive(href, current) {
      return href === '/' ? current === '/' : (current === href || current.startsWith(href + '/'));
    }
    function navClass(href, current){
      return 'nav-link' + (isActive(href, current) ? ' is-active' : '');
    }
    function navAria(href, current){
      return isActive(href, current) ? 'aria-current="page"' : '';
    }
  %>

  <% if (currentRole === 'owner') { %>
    <p class="nav-section">Operations</p>
    <nav class="space-y-1 mb-gutter-lg" aria-label="Operations">
      <a href="/"           class="<%= navClass('/',           currentPath) %>" <%- navAria('/',           currentPath) %>>Dashboard</a>
      <a href="/sales"      class="<%= navClass('/sales',      currentPath) %>" <%- navAria('/sales',      currentPath) %>>Sales</a>
      <a href="/menu"       class="<%= navClass('/menu',       currentPath) %>" <%- navAria('/menu',       currentPath) %>>Menu</a>
      <a href="/employees"  class="<%= navClass('/employees',  currentPath) %>" <%- navAria('/employees',  currentPath) %>>Employees</a>
      <a href="/purchases"  class="<%= navClass('/purchases',  currentPath) %>" <%- navAria('/purchases',  currentPath) %>>Purchases</a>
      <a href="/petty-cash" class="<%= navClass('/petty-cash', currentPath) %>" <%- navAria('/petty-cash', currentPath) %>>Petty cash</a>
      <a href="/payroll"    class="<%= navClass('/payroll',    currentPath) %>" <%- navAria('/payroll',    currentPath) %>>Payroll</a>
    </nav>

    <p class="nav-section">Owner</p>
    <nav class="space-y-1 mb-air" aria-label="Owner">
      <a href="/reports"  class="<%= navClass('/reports',  currentPath) %>" <%- navAria('/reports',  currentPath) %>>Reports</a>
      <a href="/settings" class="<%= navClass('/settings', currentPath) %>" <%- navAria('/settings', currentPath) %>>Settings</a>
    </nav>
  <% } else { %>
    <nav class="space-y-1 mb-air" aria-label="Cashier">
      <a href="/"           class="<%= navClass('/',           currentPath) %>" <%- navAria('/',           currentPath) %>>Dashboard</a>
      <a href="/sales/new"  class="<%= navClass('/sales/new',  currentPath) %>" <%- navAria('/sales/new',  currentPath) %>>New sales entry</a>
      <a href="/sales"      class="<%= navClass('/sales',      currentPath) %>" <%- navAria('/sales',      currentPath) %>>My past entries</a>
    </nav>
  <% } %>

  <% if (currentUser) { %>
    <div class="mt-auto pt-gutter-lg border-t border-rule">
      <div class="flex items-center gap-gutter">
        <div class="w-9 h-9 border border-rule-strong flex items-center justify-center wordmark text-[16px]">
          <%= initials(currentUser.full_name) %>
        </div>
        <div>
          <div class="font-sans text-[14px] text-ink leading-tight"><%= currentUser.full_name %></div>
          <div class="font-sans text-[11px] tracking-smallcaps uppercase text-smoke leading-tight mt-0.5"><%= currentUser.role %></div>
        </div>
      </div>
      <div class="flex items-center gap-gutter mt-gutter font-sans text-[12px]">
        <a href="/account" class="text-smoke hover:text-ink transition-colors">Account</a>
        <span class="text-mist">·</span>
        <form action="/logout" method="POST" class="inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="text-smoke hover:text-ink transition-colors">Log out</button>
        </form>
      </div>
    </div>
  <% } %>
</aside>

<%# Confirmation dialog — every authenticated page has the sidebar, so it has this too %>
<dialog id="confirm-dialog" class="confirm-dialog rounded-soft border border-rule-strong bg-cream p-0 w-full max-w-md text-ink shadow-2xl backdrop:bg-ink/40">
  <div class="bg-parchment">
    <header class="px-gutter-lg pt-gutter-lg pb-gutter border-b border-rule">
      <h2 id="confirm-title" class="card-title">Are you sure?</h2>
    </header>
    <div class="px-gutter-lg py-gutter-lg">
      <p id="confirm-body" class="font-sans text-[15px] text-coal"></p>
    </div>
    <div class="px-gutter-lg pb-gutter-lg flex items-center justify-end gap-gutter">
      <button type="button" data-action="cancel" class="btn-secondary">Cancel</button>
      <button type="button" data-action="confirm" id="confirm-action" class="btn-primary">Confirm</button>
    </div>
  </div>
</dialog>

<script>
  // Auto-tag the main element so the "Skip to main content" link can target it.
  (function () {
    var main = document.querySelector('main');
    if (main && !main.id) main.id = 'main';
  })();
</script>

<script>
  // Custom confirmation modal — replaces window.confirm().
  // Usage on a form:
  //   <form ... data-confirm="message body"
  //              data-confirm-title="optional title"
  //              data-confirm-label="Delete"
  //              data-confirm-variant="danger">
  (function(){
    var dialog = document.getElementById('confirm-dialog');
    if (!dialog) return;
    var titleEl = document.getElementById('confirm-title');
    var bodyEl = document.getElementById('confirm-body');
    var actionBtn = document.getElementById('confirm-action');
    var pending = null;

    function close(){ try { dialog.close(); } catch(e){} pending = null; }

    document.addEventListener('submit', function(e){
      var form = e.target;
      if (!form || form.tagName !== 'FORM') return;
      var msg = form.getAttribute('data-confirm');
      if (!msg) return;
      e.preventDefault();
      pending = form;
      titleEl.textContent = form.getAttribute('data-confirm-title') || "Are you sure?";
      bodyEl.textContent = msg;
      actionBtn.textContent = form.getAttribute('data-confirm-label') || "Confirm";
      actionBtn.className = (form.getAttribute('data-confirm-variant') === 'danger') ? 'btn-danger' : 'btn-primary';
      if (typeof dialog.showModal === 'function') {
        dialog.showModal();
        actionBtn.focus();
      } else {
        // Fallback for ancient browsers
        if (window.confirm(msg)) { form.removeAttribute('data-confirm'); form.submit(); }
        else { pending = null; }
      }
    }, true);

    dialog.addEventListener('click', function(e){
      // Clicking the backdrop (the dialog element itself, outside its content)
      if (e.target === dialog) { close(); return; }
      var act = e.target && e.target.getAttribute && e.target.getAttribute('data-action');
      if (act === 'cancel') { close(); }
      else if (act === 'confirm') {
        var f = pending;
        close();
        if (f) { f.removeAttribute('data-confirm'); f.submit(); }
      }
    });

    dialog.addEventListener('cancel', function(){ pending = null; });
  })();
</script>
