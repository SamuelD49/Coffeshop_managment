<%
  const fmt = (cents) => (cents / 100).toFixed(2);
  const _diffClass = dayDifference === 0
    ? 'text-smoke'
    : (dayDifference > 0 ? 'text-leaf' : 'text-crimson');
  const _DAY_NAMES = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
  let _dayName = '';
  const _parts = date.split('-').map(Number);
  if (_parts.length === 3 && _parts.every(n => Number.isFinite(n))) {
    const _dt = new Date(Date.UTC(_parts[0], _parts[1] - 1, _parts[2]));
    _dayName = _DAY_NAMES[_dt.getUTCDay()] || '';
  }
%>

<%# ─── Hero header ─────────────────────────────────────────── %>
<header class="day-modal-header">
  <div class="min-w-0 flex-1">
    <p class="font-mono text-[11px] tracking-smallcaps uppercase text-smoke"><%= _dayName %></p>
    <h2 class="font-display italic text-[28px] md:text-[34px] leading-[1.05] text-ink mt-1" style="font-variation-settings:'opsz' 48,'SOFT' 60">
      <%= date %>
    </h2>
    <p class="font-sans text-[13px] text-smoke mt-gutter-tight">
      <%= shifts.length %> shift<%= shifts.length === 1 ? '' : 's' %>
      <% if (shifts.length > 0) { %>
        · counted <span class="font-mono text-coal"><%= fmt(dayTotalCounted) %></span>
      <% } %>
    </p>
  </div>
</header>

<div class="day-modal-body">

  <%# ─── Stat cards ──────────────────────────────────────────── %>
  <section class="grid grid-cols-3 gap-gutter md:gap-air mb-air">
    <article class="card">
      <div class="card-body">
        <p class="font-sans font-medium text-[10px] md:text-[11px] tracking-smallcaps uppercase text-smoke">Subtotal</p>
        <p class="font-mono text-[18px] md:text-[24px] leading-[1.1] text-ink mt-gutter-tight"><%= fmt(dayTotalSubtotal) %></p>
      </div>
    </article>
    <article class="card">
      <div class="card-body">
        <p class="font-sans font-medium text-[10px] md:text-[11px] tracking-smallcaps uppercase text-smoke">Counted</p>
        <p class="font-mono text-[18px] md:text-[24px] leading-[1.1] text-ink mt-gutter-tight"><%= fmt(dayTotalCounted) %></p>
      </div>
    </article>
    <article class="card">
      <div class="card-body">
        <p class="font-sans font-medium text-[10px] md:text-[11px] tracking-smallcaps uppercase text-smoke">Difference</p>
        <p class="font-mono text-[18px] md:text-[24px] leading-[1.1] mt-gutter-tight <%= _diffClass %>"><%= dayDifference >= 0 ? '+' : '' %><%= fmt(dayDifference) %></p>
      </div>
    </article>
  </section>

  <%# ─── Shifts ──────────────────────────────────────────────── %>
  <section class="mb-air">
    <header class="flex items-baseline justify-between mb-gutter">
      <div>
        <p class="font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke">Shifts</p>
        <p class="font-display text-[18px] text-ink mt-gutter-tight" style="font-variation-settings:'opsz' 24,'SOFT' 50">By cashier</p>
      </div>
      <p class="font-mono text-[12px] text-smoke"><%= shifts.length %> total</p>
    </header>

    <% if (shifts.length === 0) { %>
      <article class="card">
        <div class="card-body text-center py-air">
          <p class="font-display italic text-[18px] text-mist" style="font-variation-settings:'opsz' 24,'SOFT' 50">No shifts on this day.</p>
        </div>
      </article>
    <% } else { %>
      <article class="card overflow-hidden">
        <%# Desktop: table %>
        <div class="hidden md:block">
          <table class="w-full">
            <thead>
              <tr class="border-b border-rule">
                <th class="text-left  font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke px-gutter-lg py-gutter">Cashier</th>
                <th class="text-right font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke py-gutter">Subtotal</th>
                <th class="text-right font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke py-gutter">Counted</th>
                <th class="text-right font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke py-gutter">Diff</th>
                <th class="text-left  font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke py-gutter pl-air">Status</th>
                <th class="text-left  font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke py-gutter pl-air">Note</th>
                <th class="px-gutter-lg"></th>
              </tr>
            </thead>
            <tbody>
              <% shifts.forEach(s => { %>
                <tr class="border-b border-rule last:border-0 hover:bg-paper transition-colors">
                  <td class="px-gutter-lg py-gutter-lg font-display text-[15px] text-ink truncate" style="font-variation-settings:'opsz' 24,'SOFT' 50"><%= empById[s.employee_id] || ('#' + s.employee_id) %></td>
                  <td class="py-gutter-lg text-right font-mono text-[14px] text-coal"><%= fmt(s.subtotal) %></td>
                  <td class="py-gutter-lg text-right font-mono text-[14px] text-coal"><%= fmt(s.total_amount) %></td>
                  <td class="py-gutter-lg text-right font-mono text-[14px] <%= s.difference === 0 ? 'text-smoke' : (s.difference > 0 ? 'text-leaf' : 'text-crimson') %>">
                    <%= s.difference >= 0 ? '+' : '' %><%= fmt(s.difference) %>
                  </td>
                  <td class="py-gutter-lg pl-air">
                    <span class="pip pip-<%= s.status === 'open' ? 'open' : 'closed' %>"><%= s.status %></span>
                  </td>
                  <td class="py-gutter-lg pl-air font-sans text-[13px] text-coal italic max-w-[200px] truncate" title="<%= s.notes || '' %>"><%= s.notes || '—' %></td>
                  <td class="px-gutter-lg py-gutter-lg text-right">
                    <a href="/sales/<%= s.id %>" class="link text-[12px] tracking-smallcaps uppercase">Open →</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <%# Mobile: stacked rows %>
        <div class="md:hidden divide-y divide-rule">
          <% shifts.forEach(s => { %>
            <a href="/sales/<%= s.id %>" class="block px-gutter-lg py-gutter-lg hover:bg-paper transition-colors">
              <div class="flex items-baseline justify-between gap-gutter">
                <div class="min-w-0">
                  <p class="font-display text-[17px] text-ink truncate" style="font-variation-settings:'opsz' 24,'SOFT' 50"><%= empById[s.employee_id] || ('#' + s.employee_id) %></p>
                  <p class="font-sans text-[12px] text-smoke mt-1 flex items-center gap-1 flex-wrap">
                    <span class="pip pip-<%= s.status === 'open' ? 'open' : 'closed' %>"><%= s.status %></span>
                    <span>· Counted <span class="font-mono text-coal"><%= fmt(s.total_amount) %></span></span>
                    <% if (s.difference !== 0) { %>
                      <span>· <span class="font-mono <%= s.difference > 0 ? 'text-leaf' : 'text-crimson' %>"><%= s.difference >= 0 ? '+' : '' %><%= fmt(s.difference) %></span></span>
                    <% } %>
                  </p>
                </div>
                <div class="text-right shrink-0">
                  <p class="font-mono text-[16px] text-ink leading-none"><%= fmt(s.subtotal) %></p>
                  <p class="font-sans text-[9px] tracking-smallcaps uppercase text-smoke mt-1">Subtotal</p>
                </div>
              </div>
              <% if (s.notes) { %>
                <p class="font-sans text-[12px] text-smoke italic mt-gutter-tight truncate">“<%= s.notes %>”</p>
              <% } %>
            </a>
          <% }) %>
        </div>
      </article>
    <% } %>
  </section>

  <%# ─── Items sold ──────────────────────────────────────────── %>
  <% if (topItems.length > 0) { %>
    <section>
      <header class="flex items-baseline justify-between mb-gutter">
        <div>
          <p class="font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke">Items sold</p>
          <p class="font-display text-[18px] text-ink mt-gutter-tight" style="font-variation-settings:'opsz' 24,'SOFT' 50">What moved today</p>
        </div>
        <p class="font-mono text-[12px] text-smoke"><%= topItems.length %> item<%= topItems.length === 1 ? '' : 's' %></p>
      </header>

      <% const _maxQty = Math.max(0, ...topItems.map(r => r.qty)); %>
      <article class="card overflow-hidden">
        <ol class="divide-y divide-rule">
          <% topItems.forEach((r, idx) => {
               const pct = _maxQty > 0 ? Math.round((r.qty / _maxQty) * 100) : 0;
          %>
            <li class="relative px-gutter-lg py-gutter-lg">
              <%# Soft bar behind the row, proportional to qty %>
              <div class="absolute inset-y-0 left-0 bg-paper/70 -z-10" style="width: <%= pct %>%"></div>
              <div class="relative flex items-baseline justify-between gap-gutter">
                <div class="flex items-baseline gap-gutter min-w-0">
                  <span class="font-mono text-[12px] text-smoke shrink-0 w-6"><%= String(idx + 1).padStart(2, '0') %></span>
                  <p class="font-display text-[16px] text-ink truncate" style="font-variation-settings:'opsz' 24,'SOFT' 50"><%= r.name %></p>
                </div>
                <div class="text-right shrink-0">
                  <p class="font-mono text-[15px] text-ink leading-none"><%= fmt(r.revenue) %></p>
                  <p class="font-sans text-[10px] tracking-smallcaps uppercase text-smoke mt-1"><%= r.qty %> sold</p>
                </div>
              </div>
            </li>
          <% }) %>
        </ol>
      </article>
    </section>
  <% } %>
</div>
