<%- include('../partials/head', { title: "Reports", shopName}) %>
<body class="text-ink font-sans antialiased min-h-screen flex">
  <%- include('../partials/sidebar', { shopName, currentRole, currentUser, csrfToken, currentPath }) %>

  <main class="flex-1 px-air-lg pt-chapter pb-air-lg max-w-5xl">
    <header class="reveal reveal-1 flex items-end justify-between flex-wrap gap-gutter">
      <div>
        <p class="font-mono text-[12px] tracking-smallcaps uppercase text-smoke">Analytics</p>
        <h1 class="font-display text-[36px] leading-[42px] text-ink mt-gutter-tight" style="font-variation-settings:'opsz' 72,'SOFT' 50">Reports</h1>
      </div>
      <div class="flex items-center gap-gutter">
        <a href="/reports/print?tab=<%= tab %>&from=<%= range.from %>&to=<%= range.to %>" target="_blank" class="btn-secondary">Print</a>
        <a href="/reports/export?tab=<%= tab %>&from=<%= range.from %>&to=<%= range.to %>" class="btn-primary">Download CSV</a>
      </div>
    </header>

    <div class="reveal reveal-2"><%- include('../partials/ornament') %></div>

    <%- include('../partials/flash', { flash }) %>

    <% const tabs = [
        { key: 'sales',      label: "Sales" },
        { key: 'purchases',  label: "Purchases" },
        { key: 'petty-cash', label: "Petty cash" },
        { key: 'payroll',    label: "Payroll" },
    ]; %>

    <nav class="reveal reveal-3 border-b border-rule-strong flex gap-air-lg mb-air overflow-x-auto">
      <% tabs.forEach(tb => { %>
        <a href="/reports?tab=<%= tb.key %>&from=<%= range.from %>&to=<%= range.to %>"
           class="relative pb-gutter font-sans text-[14px] transition-colors whitespace-nowrap <%= tab === tb.key ? 'text-ink' : 'text-smoke hover:text-coal' %>">
          <%= tb.label %>
          <% if (tab === tb.key) { %>
            <span class="absolute left-0 right-0 -bottom-px h-[2px] bg-ember"></span>
          <% } %>
        </a>
      <% }) %>
    </nav>

    <%
      function _shift(yyyymmdd, days) {
        const [y, m, d] = yyyymmdd.split("-").map(Number);
        const dt = new Date(Date.UTC(y, m - 1, d));
        dt.setUTCDate(dt.getUTCDate() + days);
        return dt.toISOString().slice(0, 10);
      }
      const _today = range.to;
      const _yesterday = _shift(_today, -1);
      const _last7From = _shift(_today, -6);
      const _last30From = _shift(_today, -29);
      const _thisMonthFrom = _today.slice(0, 7) + "-01";
      const [_ty, _tm] = _today.split("-").map(Number);
      const _lastMonthDate = new Date(Date.UTC(_ty, _tm - 2, 1));
      const _lmYear = _lastMonthDate.getUTCFullYear();
      const _lmMonth = String(_lastMonthDate.getUTCMonth() + 1).padStart(2, "0");
      const _lastMonthFrom = `${_lmYear}-${_lmMonth}-01`;
      const _lastMonthTo = _shift(`${_today.slice(0, 7)}-01`, -1);

      const _presets = [
        { label: "Today",      from: _today,         to: _today      },
        { label: "Yesterday",  from: _yesterday,     to: _yesterday  },
        { label: "Last 7 days",       from: _last7From,     to: _today      },
        { label: "Last 30 days",     from: _last30From,    to: _today      },
        { label: "This month",  from: _thisMonthFrom, to: _today      },
        { label: "Last month",  from: _lastMonthFrom, to: _lastMonthTo },
      ];
      function _isActive(p) { return p.from === range.from && p.to === range.to; }
    %>

    <div class="mb-gutter">
      <p class="font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke mb-gutter-tight">Quick range</p>
      <div class="flex flex-wrap items-center gap-gutter-tight">
        <% _presets.forEach(p => { %>
          <a href="/reports?tab=<%= tab %>&from=<%= p.from %>&to=<%= p.to %>"
             class="inline-block font-sans text-[12px] tracking-button uppercase px-3 py-1.5 rounded-soft border transition-colors
                    <%= _isActive(p)
                        ? 'border-ink bg-ink text-cream'
                        : 'border-rule-strong text-coal hover:bg-paper hover:text-ink' %>">
            <%= p.label %>
          </a>
        <% }) %>
      </div>
    </div>

    <form method="GET" class="flex items-end gap-gutter mb-air flex-wrap">
      <input type="hidden" name="tab" value="<%= tab %>" />
      <label class="block">
        <span class="field-label">From</span>
        <input type="date" name="from" value="<%= range.from %>" class="field-input field-mono" />
      </label>
      <label class="block">
        <span class="field-label">To</span>
        <input type="date" name="to" value="<%= range.to %>" class="field-input field-mono" />
      </label>
      <button class="btn-secondary">Apply</button>
    </form>

    <% if (tab === 'sales')      { %><%- include('_sales',     { data, range, csrfToken }) %><% } %>
    <% if (tab === 'purchases')  { %><%- include('_purchases', { data, range, csrfToken }) %><% } %>
    <% if (tab === 'petty-cash') { %><%- include('_pettyCash', { data, range, csrfToken }) %><% } %>
    <% if (tab === 'payroll')    { %><%- include('_payroll',   { data, range, csrfToken }) %><% } %>
  </main>
</body>
</html>
