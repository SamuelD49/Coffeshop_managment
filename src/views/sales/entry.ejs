<%- include('../partials/head', { title: 'Sales · ' + session.business_date, shopName }) %>
<body class="text-ink font-sans antialiased min-h-screen flex">
  <%- include('../partials/sidebar', { shopName, currentRole, currentUser, csrfToken, currentPath }) %>

  <main class="flex-1 px-air-lg pt-chapter pb-air-lg max-w-5xl">
    <header class="reveal reveal-1 flex items-end justify-between">
      <div>
        <p class="font-mono text-[12px] tracking-smallcaps uppercase text-smoke">
          <a href="/sales" class="hover:text-ink transition-colors">Sales</a>
        </p>
        <h1 class="font-display text-[36px] leading-[42px] text-ink mt-gutter-tight" style="font-variation-settings:'opsz' 72,'SOFT' 50">
          <%= session.business_date %><% if (session.shift) { %> · <span class="italic"><%= session.shift %></span><% } %>
        </h1>
        <p class="font-sans text-[13px] text-smoke mt-gutter-tight">
          <% if (employee) { %>Cashier: <%= employee.full_name %> · <% } %>
          <span class="pip pip-<%= session.status === 'open' ? 'open' : 'closed' %>"><%= session.status %></span>
        </p>
      </div>
      <div class="flex items-center gap-gutter">
        <% if (editable) { %>
          <form method="POST" action="/sales/<%= session.id %>/close"
                data-confirm="Close this entry? You will not be able to edit it after."
                data-confirm-title="Close entry?"
                data-confirm-label="Close entry">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn-primary">Close entry →</button>
          </form>
        <% } else if (currentRole === 'owner') { %>
          <form method="POST" action="/sales/<%= session.id %>/reopen">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn-secondary">Reopen entry</button>
          </form>
        <% } %>
        <% if (currentRole === 'owner') { %>
          <form method="POST" action="/sales/<%= session.id %>/delete"
                data-confirm="This sales record and all its line items will be permanently removed. This can't be undone."
                data-confirm-title="Delete this sales record?"
                data-confirm-label="Delete"
                data-confirm-variant="danger">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn-danger">Delete</button>
          </form>
        <% } %>
      </div>
    </header>

    <div class="reveal reveal-2"><%- include('../partials/ornament') %></div>

    <%- include('../partials/flash', { flash }) %>

    <div class="reveal reveal-3 card overflow-hidden">
      <table class="w-full table-fixed">
        <colgroup>
          <col style="width: 32%" />
          <col style="width: 12%" />
          <col style="width: 12%" />
          <col style="width: 14%" />
          <col style="width: 30%" />
        </colgroup>
        <thead>
          <tr class="border-b border-rule-strong">
            <th class="text-left font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke px-gutter-lg py-gutter">Item</th>
            <th class="text-right font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke py-gutter">Unit</th>
            <th class="text-left font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke py-gutter pl-gutter-lg">Qty</th>
            <th class="text-right font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke px-gutter-lg py-gutter">Total</th>
            <th class="text-left font-sans font-medium text-[11px] tracking-smallcaps uppercase text-smoke py-gutter pl-gutter-lg border-l-2 border-rule-strong bg-paper">Tally</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(item => {
               const line = lines[item.id] || null;
          %>
            <%- include('_row', { item, line, session, csrfToken, totals }) %>
          <% }) %>
        </tbody>
      </table>

      <%- include('_totals', { totals }) %>

      <% if (editable) { %>
        <form
          class="px-gutter-lg py-gutter-lg border-t border-rule grid grid-cols-3 gap-air items-end"
          hx-post="/sales/<%= session.id %>/header"
          hx-headers='{"x-csrf-token": "<%= csrfToken %>"}'
          hx-target="#totals"
          hx-swap="outerHTML"
          hx-trigger="input changed delay:300ms from:input[name='cash_amount'], input changed delay:300ms from:input[name='bank_transfer_amount'], change from:input[name='notes']"
        >
          <label class="block">
            <span class="field-label">Cash collected</span>
            <input name="cash_amount" value="<%= (session.cash_amount / 100).toFixed(2) %>" inputmode="decimal" oninput="window.recalcSales && window.recalcSales(this)" class="field-input field-mono" />
          </label>
          <label class="block">
            <span class="field-label">Bank transfer</span>
            <input name="bank_transfer_amount" value="<%= (session.bank_transfer_amount / 100).toFixed(2) %>" inputmode="decimal" oninput="window.recalcSales && window.recalcSales(this)" class="field-input field-mono" />
          </label>
          <label class="block">
            <span class="field-label">Notes</span>
            <input name="notes" value="<%= session.notes || '' %>" class="field-input" />
          </label>
        </form>
      <% } else { %>
        <div class="px-gutter-lg py-gutter-lg border-t border-rule grid grid-cols-3 gap-air">
          <div>
            <p class="field-label">Cash collected</p>
            <p class="font-mono text-[16px] text-ink"><%= (session.cash_amount / 100).toFixed(2) %></p>
          </div>
          <div>
            <p class="field-label">Bank transfer</p>
            <p class="font-mono text-[16px] text-ink"><%= (session.bank_transfer_amount / 100).toFixed(2) %></p>
          </div>
          <div>
            <p class="field-label">Notes</p>
            <p class="font-sans text-[14px] text-coal"><%= session.notes || '—' %></p>
          </div>
        </div>
      <% } %>
    </div>
  </main>

  <script>
    // Real-time totals. Server still reconciles via HTMX after 300ms — this is purely
    // client-side preview so numbers move on every keystroke.
    (function () {
      function asMoneyCents(value) {
        var n = Number(String(value || '').replace(/[, ]/g, ''));
        return Number.isFinite(n) ? Math.round(n * 100) : 0;
      }
      function asQty(value) {
        var n = Math.floor(Number(value || 0));
        return Number.isFinite(n) && n > 0 ? n : 0;
      }
      function fmt(cents) { return (cents / 100).toFixed(2); }

      // Render the buna jar for one row. `popLastN` adds the pop animation to
      // the last N newly-added disks (used when the cashier drops a token so
      // there's a satisfying visual cue).
      function renderJar(row, popLastN) {
        var jar = row.querySelector('[data-jar]');
        if (!jar) return;
        var qty = asQty(row.querySelector('input[name="qty"]').value);
        var color = row.dataset.tokenColor || '#C75D34';
        var maxVisible = 60;
        var visible = Math.min(qty, maxVisible);
        var pop = popLastN || 0;
        var html = '';
        for (var i = 0; i < visible; i++) {
          var isPop = (i >= visible - pop) ? ' token-pop' : '';
          html += '<span class="token-disk-small' + isPop + '" style="background-color:' + color + '" aria-hidden="true"></span>';
        }
        if (qty > maxVisible) {
          html += '<span class="font-mono text-[10px] text-smoke ml-1">+' + (qty - maxVisible) + '</span>';
        }
        jar.innerHTML = html;
      }

      // "Drop a token" — increment qty by 1 and trigger the same input pipeline
      // (recalc + debounced HTMX save) that typing the number does.
      window.dropToken = function (btn) {
        var row = btn.closest('tr[data-unit-price]');
        if (!row) return;
        var input = row.querySelector('input[name="qty"]');
        var current = asQty(input.value);
        input.value = String(current + 1);
        // Re-render this jar immediately with a pop on the new token, then let
        // recalcSales run the regular pass for everything else.
        renderJar(row, 1);
        // Fire input event so HTMX picks it up.
        input.dispatchEvent(new Event('input', { bubbles: true }));
      };

      // Clicking a small disk in the jar removes one token (intuitive: pick it
      // back out). Event delegation since the jar re-renders.
      document.addEventListener('click', function (e) {
        var t = e.target;
        if (!t || !t.classList || !t.classList.contains('token-disk-small')) return;
        var row = t.closest('tr[data-unit-price]');
        if (!row) return;
        var input = row.querySelector('input[name="qty"]');
        var current = asQty(input.value);
        if (current <= 0) return;
        input.value = String(current - 1);
        input.dispatchEvent(new Event('input', { bubbles: true }));
      });

      window.recalcSales = function () {
        var subtotal = 0;
        var items = 0;
        document.querySelectorAll('tr[data-unit-price]').forEach(function (row) {
          var unit = Number(row.dataset.unitPrice) || 0;
          var qty = asQty(row.querySelector('input[name="qty"]').value);
          var lineTotal = unit * qty;
          subtotal += lineTotal;
          items += qty;
          var rt = row.querySelector('[id^="row-total-"]');
          if (rt) rt.textContent = fmt(lineTotal);
          renderJar(row, 0);
        });

        var cashInput = document.querySelector('input[name="cash_amount"]');
        var bankInput = document.querySelector('input[name="bank_transfer_amount"]');
        var cash = cashInput ? asMoneyCents(cashInput.value) : 0;
        var bank = bankInput ? asMoneyCents(bankInput.value) : 0;
        var counted = cash + bank;
        var diff = counted - subtotal;

        var elS = document.getElementById('totals-subtotal');
        if (elS) elS.textContent = fmt(subtotal);
        var elC = document.getElementById('totals-counted');
        if (elC) elC.textContent = fmt(counted);
        var elI = document.getElementById('totals-items');
        if (elI) elI.textContent = String(items);
        var elD = document.getElementById('totals-difference');
        if (elD) {
          elD.textContent = (diff >= 0 ? '+' : '') + fmt(diff);
          elD.classList.remove('text-leaf', 'text-crimson', 'text-smoke');
          elD.classList.add(diff === 0 ? 'text-smoke' : (diff > 0 ? 'text-leaf' : 'text-crimson'));
        }
      };

      // Run once on load to populate "items sold" and reconcile any cached state.
      document.addEventListener('DOMContentLoaded', window.recalcSales);
      // Re-run after HTMX swaps so the values stay in sync with server-canonical state.
      document.body.addEventListener('htmx:afterSwap', window.recalcSales);
    })();
  </script>
</body>
</html>
